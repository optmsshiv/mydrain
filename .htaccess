RewriteEngine On

# ── 1. Redirect /index.php to / (clean home URL) ──────────────────────────────
RewriteRule ^index\.php$ / [R=301,L]

# ── 2. Strip .php from URLs (301 redirect) ────────────────────────────────────
#    e.g. /pages/about.php  →  /pages/about
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── 3. Redirect .html requests to .php equivalent (301 permanent) ─────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# ── 4. Internally rewrite clean URL → .php file ───────────────────────────────
#    e.g. /pages/about  →  /pages/about.php (no redirect, transparent)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^.]+)$ $1.php [NC,L]
