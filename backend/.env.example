# ─── My Drain DR — Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Gmail Setup ──────────────────────────────────────────────────────────────
# Your Gmail address (the one that sends & receives inquiries)
GMAIL_USER=youremail@gmail.com

# Gmail App Password — NOT your Gmail login password.
# Generate one at: https://myaccount.google.com/apppasswords
#   1. Go to Google Account → Security → 2-Step Verification (must be ON)
#   2. Search "App passwords" → Create → Select app: Mail → Device: Other → "MyDrainDR"
#   3. Copy the 16-character password (spaces are OK)
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Where business inquiry notifications are sent (can be same as GMAIL_USER)
OWNER_EMAIL=owner@gmail.com

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Security ─────────────────────────────────────────────────────────────────
# Secret key to access /api/admin/inquiries — change this!
ADMIN_KEY=change-this-secret-key-123

# Allowed CORS origin (your domain in production, * for local dev)
ALLOWED_ORIGIN=*
